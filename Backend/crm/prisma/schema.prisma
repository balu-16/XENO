generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  MANAGER
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ChannelType {
  WHATSAPP
  SMS
  EMAIL
  RCS
}

enum CampaignStatus {
  DRAFT
  QUEUED
  RUNNING
  PAUSED
  COMPLETED
  FAILED
}

enum CampaignEventType {
  CampaignCreated
  CampaignLaunched
  MessageQueued
  MessageSent
  MessageDelivered
  MessageOpened
  MessageClicked
  MessageConverted
  MessageFailed
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  CONVERTED
  FAILED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum ToolExecutionStatus {
  STARTED
  PENDING_CONFIRMATION
  COMPLETED
  CANCELED
  FAILED
}

model User {
  id               String              @id @default(uuid())
  name             String
  email            String              @unique
  passwordHash     String
  emailVerified    Boolean             @default(false)
  role             UserRole            @default(MANAGER)
  approvalStatus   ApprovalStatus      @default(PENDING)
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  conversations    AIConversation[]
  refreshTokens    RefreshToken[]
  emailVerifications EmailVerification[]
}

model Customer {
  id             String          @id @default(uuid())
  name           String
  email          String          @unique
  phone          String
  tags           String[]        @default([])
  metadata       Json
  createdAt      DateTime        @default(now())
  orders         Order[]
  campaignLogs   CampaignLog[]
  campaignEvents CampaignEvent[]

  @@index([name])
  @@index([createdAt])
  @@index([tags], type: Gin)
}

model Order {
  id             String         @id @default(uuid())
  customerId     String
  customer       Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  amount         Decimal        @db.Decimal(12, 2)
  items          Json
  createdAt      DateTime       @default(now())
  campaignLogs   CampaignLog[]
  campaignEvents CampaignEvent[]

  @@index([customerId, createdAt])
  @@index([createdAt])
}

model Segment {
  id          String     @id @default(uuid())
  name        String
  description String?
  rules       Json
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  campaigns   Campaign[]

  @@index([createdAt])
  @@index([name])
}

model Campaign {
  id                   String              @id @default(uuid())
  name                 String
  segmentId            String
  segment              Segment             @relation(fields: [segmentId], references: [id])
  channel              ChannelType
  status               CampaignStatus      @default(DRAFT)
  subject              String?
  message              String
  audienceSizeSnapshot Int                 @default(0)
  scheduledAt          DateTime?
  launchedAt           DateTime?
  completedAt          DateTime?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  logs                 CampaignLog[]
  events               CampaignEvent[]
  analytics            CampaignAnalytics?
  webhookReceipts      WebhookReceipt[]

  @@index([segmentId])
  @@index([status, createdAt])
  @@index([channel])
  @@index([scheduledAt])
}

model CampaignEvent {
  id                String            @id @default(uuid())
  eventId           String            @unique
  type              CampaignEventType
  campaignId        String
  campaign          Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId        String?
  customer          Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  attributedOrderId String?
  attributedOrder   Order?            @relation(fields: [attributedOrderId], references: [id])
  correlationId     String
  payload           Json
  occurredAt        DateTime
  createdAt         DateTime          @default(now())

  @@index([campaignId, type, occurredAt])
  @@index([customerId, occurredAt])
  @@index([correlationId])
}

model CampaignLog {
  id                String         @id @default(uuid())
  campaignId        String
  campaign          Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId        String
  customer          Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  status            DeliveryStatus
  failureReason     String?
  attributedOrderId String?        @unique
  attributedOrder   Order?         @relation(fields: [attributedOrderId], references: [id])
  lastEventAt       DateTime
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@unique([campaignId, customerId])
  @@index([campaignId, status])
  @@index([customerId, updatedAt])
}

model CampaignAnalytics {
  id             String   @id @default(uuid())
  campaignId     String   @unique
  campaign       Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  totalAudience  Int      @default(0)
  totalQueued    Int      @default(0)
  totalSent      Int      @default(0)
  totalDelivered Int      @default(0)
  totalOpened    Int      @default(0)
  totalClicked   Int      @default(0)
  totalConverted Int      @default(0)
  totalFailed    Int      @default(0)
  deliveryRate   Float    @default(0)
  openRate       Float    @default(0)
  clickRate      Float    @default(0)
  conversionRate Float    @default(0)
  revenueAccrued Decimal  @default(0) @db.Decimal(14, 2)
  updatedAt      DateTime @updatedAt

  @@index([updatedAt])
}

model WebhookReceipt {
  id            String            @id @default(uuid())
  eventId       String            @unique
  campaignId    String
  campaign      Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customerId    String
  type          CampaignEventType
  correlationId String
  payload       Json
  receivedAt    DateTime          @default(now())
  processedAt   DateTime?
  attempts      Int               @default(0)
  error         String?

  @@index([receivedAt])
  @@index([campaignId, receivedAt])
}

model AIConversation {
  id        String            @id @default(uuid())
  userId    String?
  title     String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  user      User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  messages  AIMessage[]
  tools     AIToolExecution[]
  decisions AIDecisionLog[]

  @@index([userId])
  @@index([updatedAt])
}

model AIMessage {
  id             String         @id @default(uuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String
  grounding      Json?
  createdAt      DateTime       @default(now())

  @@index([conversationId, createdAt])
}

model AIToolExecution {
  id                   String              @id @default(uuid())
  conversationId       String
  conversation         AIConversation      @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  toolName             String
  providerCallId       String?
  round                Int                 @default(0)
  status               ToolExecutionStatus
  input                Json
  output               Json?
  sources              Json?
  error                 String?
  durationMs            Int?
  inputTokens          Int                 @default(0)
  outputTokens         Int                 @default(0)
  requiresConfirmation Boolean             @default(false)
  confirmedAt          DateTime?
  confirmedBy          String?
  createdAt            DateTime            @default(now())
  completedAt          DateTime?

  @@index([conversationId, createdAt])
  @@index([toolName, createdAt])
  @@index([providerCallId])
}

model AIDecisionLog {
  id                       String         @id @default(uuid())
  conversationId           String
  conversation             AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId                   String?
  prompt                   String
  round                    Int
  toolsAvailable           String[]
  toolChosen               String?
  providerCallId           String?
  inputTokens              Int            @default(0)
  outputTokens             Int            @default(0)
  executionTimeMs          Int
  success                  Boolean        @default(true)
  error                    String?
  createdAt                DateTime       @default(now())

  @@index([conversationId, createdAt])
  @@index([toolChosen, createdAt])
  @@index([userId, createdAt])
}

model ProcessingFailure {
  id            String   @id @default(uuid())
  queue         String
  jobId         String?
  correlationId String?
  reason        String
  diagnostics   Json
  createdAt     DateTime @default(now())
  resolvedAt    DateTime?

  @@index([queue, createdAt])
}

model CustomerLoginLog {
  id         String   @id @default(uuid())
  customerId String
  email      String
  ip         String?
  userAgent  String?
  loggedInAt DateTime @default(now())

  @@index([customerId, loggedInAt])
}

model AdminLoginLog {
  id         String   @id @default(uuid())
  userId     String
  email      String
  role       String
  ip         String?
  userAgent  String?
  loggedInAt DateTime @default(now())

  @@index([userId, loggedInAt])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model EmailVerification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum InsightType {
  REVENUE
  CUSTOMER
  CAMPAIGN
  SEGMENT
  CHURN
  DELIVERY
  CONVERSION
  OPPORTUNITY
  ANOMALY
  PREDICTION
}

enum InsightPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum InsightStatus {
  ACTIVE
  DISMISSED
  COMPLETED
  EXPIRED
  ACTIONED
}

enum InsightActionType {
  GENERATE_SEGMENT
  CREATE_CAMPAIGN
  LAUNCH_CAMPAIGN
  SEND_RETENTION_OFFER
  EXPORT_CSV
  VIEW_DETAILS
}

enum InsightActionStatus {
  GENERATED
  CLICKED
  EXECUTED
  FAILED
}

enum InsightFeedbackRating {
  USEFUL
  NOT_USEFUL
}

model AIInsight {
  id               String         @id @default(uuid())
  type             InsightType
  priority         InsightPriority
  fingerprint      String         @unique
  title            String
  summary          String
  details          Json
  recommendation   String
  estimatedImpact  String?
  confidenceScore  Float          @default(0.5)
  confidenceFactors Json?
  impactScore      Float          @default(0.5)
  priorityScore    Float          @default(0.5)
  status           InsightStatus  @default(ACTIVE)
  sourceData       Json?
  correlationId    String?
  generatedAt      DateTime       @default(now())
  expiresAt        DateTime
  dismissedAt      DateTime?
  completedAt      DateTime?
  actionedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  actions          AIInsightAction[]
  outcomes         AIInsightOutcome[]
  feedback         AIInsightFeedback[]

  @@index([type, status])
  @@index([priority, status])
  @@index([status, generatedAt])
  @@index([fingerprint])
  @@index([expiresAt])
  @@index([correlationId])
}

model AIInsightAction {
  id              String              @id @default(uuid())
  insightId       String
  insight         AIInsight           @relation(fields: [insightId], references: [id], onDelete: Cascade)
  type            InsightActionType
  label           String
  description     String?
  status          InsightActionStatus @default(GENERATED)
  metadata        Json?
  executedResult  Json?
  clickedAt       DateTime?
  executedAt      DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([insightId])
  @@index([status])
}

model AIInsightOutcome {
  id               String    @id @default(uuid())
  insightId        String
  insight          AIInsight @relation(fields: [insightId], references: [id], onDelete: Cascade)
  predictedImpact  String
  actualImpact     String?
  predictedValue   Float?
  actualValue      Float?
  accuracy         Float?
  actionTaken      String
  measuredAt       DateTime
  createdAt        DateTime  @default(now())

  @@index([insightId])
  @@index([measuredAt])
}

model AIInsightFeedback {
  id        String                @id @default(uuid())
  insightId String
  insight   AIInsight             @relation(fields: [insightId], references: [id], onDelete: Cascade)
  userId    String?
  rating    InsightFeedbackRating
  comment   String?
  createdAt DateTime             @default(now())

  @@unique([insightId, userId])
  @@index([insightId])
}

model AIInsightCorrelation {
  id          String   @id @default(uuid())
  title       String
  summary     String
  insightIds  String[]
  rootCause   String
  recommendation String
  score       Float
  generatedAt DateTime @default(now())
  expiresAt   DateTime

  @@index([generatedAt])
}

model AIExecutiveScore {
  id             String   @id @default(uuid())
  overallScore   Float
  revenueScore   Float
  engagementScore Float
  churnScore     Float
  deliveryScore  Float
  campaignScore  Float
  factors        Json
  trend          String
  generatedAt    DateTime @default(now())

  @@index([generatedAt])
}
